# =============================================================================
# Canvas LMS Self-Hosted — Environment Variables
# Copy this file to .env and fill in all values before running setup.sh
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN & APPLICATION
# -----------------------------------------------------------------------------
CANVAS_DOMAIN=canvas.yourdomain.com
CANVAS_LMS_VERSION=stable          # Docker image tag (stable | latest | vX.Y.Z)
RAILS_ENV=production

# -----------------------------------------------------------------------------
# ADMIN ACCOUNT (created automatically by setup.sh)
# -----------------------------------------------------------------------------
CANVAS_ADMIN_EMAIL=admin@yourdomain.com
CANVAS_ADMIN_PASSWORD=ChangeMe123!
CANVAS_ADMIN_NAME=Administrator

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=canvas_production
POSTGRES_USER=canvas
POSTGRES_PASSWORD=SuperSecretDBPassword!
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# CACHE & JOBS (Redis)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# OUTGOING EMAIL (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASSWORD=YourSmtpPassword!
SMTP_DOMAIN=yourdomain.com
SMTP_FROM=no-reply@yourdomain.com
# Authentication type: plain | login | cram_md5
SMTP_AUTH=plain
# Encryption: starttls | tls | none
SMTP_STARTTLS=starttls

# -----------------------------------------------------------------------------
# SECURITY KEYS  (generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------------
# Used to encrypt cookies and sessions — KEEP SECRET
CANVAS_SECRET_KEY_BASE=REPLACE_WITH_64_CHAR_HEX_SECRET
# Used for internal Canvas encryption
CANVAS_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
# local | s3
CANVAS_STORAGE_BACKEND=local
CANVAS_UPLOADS_PATH=/var/canvas/uploads

# --- S3 settings (only required when CANVAS_STORAGE_BACKEND=s3) ---
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=canvas-uploads

# -----------------------------------------------------------------------------
# SSL / TLS
# -----------------------------------------------------------------------------
# Set to true to enable automatic Let's Encrypt certificate via Nginx
SSL_ENABLED=true
SSL_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# FEATURE FLAGS (optional overrides)
# -----------------------------------------------------------------------------
CANVAS_HORIZON_UI=true
CANVAS_NEW_GRADEBOOK=true
CANVAS_QUIZZES_NEXT=false

# -----------------------------------------------------------------------------
# DOCKER COMPOSE RESOURCE LIMITS (optional)
# -----------------------------------------------------------------------------
CANVAS_CPU_LIMIT=2
CANVAS_MEM_LIMIT=4g
POSTGRES_CPU_LIMIT=1
POSTGRES_MEM_LIMIT=2g
REDIS_MEM_LIMIT=512m
